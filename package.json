{
  "name": "taskflow-api",
  "version": "1.0.0",
  "description": "TaskFlow API - a production-style Task Management REST API used to demonstrate a full 7-stage Jenkins CI/CD pipeline (SIT753 HD Task).",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "express",
    "rest-api",
    "devops",
    "jenkins",
    "ci-cd",
    "prometheus"
  ],
  "author": "Zaid",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
