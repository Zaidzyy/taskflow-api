# TaskFlow API — example environment file.
# Copy this to .env before running docker compose:   cp .env.example .env
# .env is gitignored, so your real values never get committed.

# API key required for write operations (POST/PUT/DELETE) via the X-API-Key header.
# docker compose reads this value and injects it into the container.
API_KEY=dev-local-api-key-change-me

# Version string surfaced at /health (docker compose passes this through).
APP_VERSION=local-dev

# --- The variables below are read by the app when you run it directly with
# --- `npm start`. Under docker compose, PORT and NODE_ENV are fixed by
# --- docker-compose.yml, so changing them here only affects `npm start`.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
